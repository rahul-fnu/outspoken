{
  "$schema": "https://raw.githubusercontent.com/nicoulaj/tauri-schema/refs/heads/main/schema.json",
  "productName": "Outspoken",
  "version": "0.1.0",
  "identifier": "com.outspoken.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "title": "Outspoken",
    "windows": [
      {
        "title": "Outspoken",
        "width": 800,
        "height": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
